<Window x:Class="Inkbridge.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inkbridge Overlay Mode" Height="400" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="#05000000"
        ResizeMode="CanResizeWithGrip" Topmost="True"
        Loaded="OnLoaded" Closed="OnClosed" MouseLeftButtonDown="OnWindowDrag">
    <Border BorderBrush="#F00" BorderThickness="2" Background="Transparent" Margin="0,0,-8,-8">
        <Grid>
            <!-- Canvas to hold strokes from Android -->
            <Canvas x:Name="OverlayCanvas" Background="Transparent" ClipToBounds="True"/>
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10" Orientation="Horizontal">
                <Button Content="Close &amp; Export" Click="OnCloseClicked" Background="#F44" Foreground="White" Padding="10,4" Margin="0,0,10,0"/>
                <TextBlock Text="Resize from bottom-right to fit area" Foreground="White" Background="#88000000" Padding="4" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
