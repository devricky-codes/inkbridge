<Window x:Class="Inkbridge.Windows.WhiteboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inkbridge Whiteboard" Height="720" Width="1080"
        Background="#0A0A0A" AllowDrop="True"
        Drop="OnDrop" DragOver="OnDragOver">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4"
                    HorizontalAlignment="Right">
            <ToggleButton x:Name="PanToggle" Content="🤚 Pan" Margin="4,0,12,0"
                          Background="#222" Foreground="#AAD" BorderBrush="#446"
                          Padding="10,4" Click="OnPanToggle"/>
            <ToggleButton x:Name="DocModeToggle" Content="📄 Doc Mode" Margin="4,0"
                          Background="#222" Foreground="#DDF" BorderBrush="#333"
                          Padding="10,4" Click="OnDocModeToggle"/>
            <StackPanel x:Name="DocUI" Orientation="Horizontal" Visibility="Collapsed">
                <Button Content="Save Page" Click="OnDocSave" Margin="4,0"
                        Background="#222" Foreground="#DDF" BorderBrush="#333"
                        Padding="10,4"/>
                <Button Content="Next Page" Click="OnDocNext" Margin="4,0"
                        Background="#222" Foreground="#DDF" BorderBrush="#333"
                        Padding="10,4"/>
            </StackPanel>
            <Button Content="Open Overlay" Click="OnOpenOverlay" Margin="8,0,4,0"
                    Background="#2A2A2A" Foreground="#F00" BorderBrush="#633"
                    Padding="10,4"/>
            <Button Content="Add Image" Click="OnAddImage" Margin="4,0"
                    Background="#222" Foreground="#AAA" BorderBrush="#333"
                    Padding="10,4"/>
            <Button Content="Add Link" Click="OnAddLink" Margin="4,0"
                    Background="#222" Foreground="#AAA" BorderBrush="#333"
                    Padding="10,4"/>
            <Button Content="Export PNG" Click="OnExportPng" Margin="4,0"
                    Background="#222" Foreground="#AFA" BorderBrush="#333"
                    Padding="10,4"/>
            <Button Content="Manual" Click="OnShowManual" Margin="4,0"
                    Background="#222" Foreground="#FAA" BorderBrush="#333"
                    Padding="10,4"/>
            <Button Content="Save" Click="OnSave" Margin="4,0"
                    Background="#222" Foreground="#6A6" BorderBrush="#333"
                    Padding="10,4"/>
            <Button Content="Load" Click="OnLoad" Margin="4,0"
                    Background="#222" Foreground="#68F" BorderBrush="#333"
                    Padding="10,4"/>
            <Button Content="Clear" Click="OnClear" Margin="4,0"
                    Background="#222" Foreground="#666" BorderBrush="#333"
                    Padding="10,4"/>
            <Button Content="🔄 Sync to Tablet" Click="OnSyncToTablet" Margin="8,0,4,0"
                    Background="#2A2A2A" Foreground="#F80" BorderBrush="#F80"
                    Padding="10,4"/>
        </StackPanel>

        <!-- Canvas with scroll/zoom -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto" Background="#0A0A0A"
                      x:Name="ScrollHost"
                      PreviewMouseDown="OnScrollHostMouseDown"
                      PreviewMouseMove="OnScrollHostMouseMove"
                      PreviewMouseUp="OnScrollHostMouseUp">
            <Canvas x:Name="WhiteboardCanvas" Width="4000" Height="4000"
                                        Background="#0A0A0A"
                                        MouseWheel="OnCanvasMouseWheel">
                                <Canvas.RenderTransform>
                                        <TransformGroup>
                                                <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                                                <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0"/>
                                        </TransformGroup>
                                </Canvas.RenderTransform>
                        </Canvas>
        </ScrollViewer>

        <!-- Sending overlay -->
        <Border x:Name="SendingOverlay" Grid.Row="0" Grid.RowSpan="2"
                Background="#CC000000" Visibility="Collapsed"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="SendingLabel" Text="Sending image..."
                           Foreground="White" FontSize="20"
                           HorizontalAlignment="Center"/>
                <ProgressBar x:Name="SendingProgress" Width="300" Height="20"
                             Margin="0,12,0,0" Minimum="0" Maximum="100"
                             Foreground="#4488FF"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
