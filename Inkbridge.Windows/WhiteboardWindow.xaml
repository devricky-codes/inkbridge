<Window x:Class="Inkbridge.Windows.WhiteboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inkbridge Whiteboard" Height="720" Width="1080"
        Background="#0A0A0A" AllowDrop="True"
        Drop="OnDrop" DragOver="OnDragOver">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="#EEEEFF"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A4A6A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F1F30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="#EEEEFF"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4477FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A4A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#161622" Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="Bg Hex:" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="BgColorInput" Text="#0A0A0A" Width="70" Background="#0C0C12" Foreground="#FFF"
                             BorderThickness="1" BorderBrush="#333" Padding="4" VerticalContentAlignment="Center"
                             TextChanged="OnBgColorChanged"/>
                </StackPanel>

                <ToggleButton x:Name="PanToggle" Content="🤚 Pan" Margin="0,0,12,0"
                              Click="OnPanToggle"/>
                <ToggleButton x:Name="DocModeToggle" Content="📄 Doc Mode" Click="OnDocModeToggle"/>
                <StackPanel x:Name="DocUI" Orientation="Horizontal" Visibility="Collapsed">
                    <Button Content="Save Page" Click="OnDocSave"/>
                    <Button Content="Next Page" Click="OnDocNext"/>
                </StackPanel>

                <Button Content="Open Overlay" Click="OnOpenOverlay" Background="#7F3333"/>
                <Button Content="Add Image" Click="OnAddImage"/>
                <Button Content="Add Link" Click="OnAddLink"/>
                <Button Content="Export PNG" Click="OnExportPng"/>
                <Button Content="Manual" Click="OnShowManual"/>
                <Button Content="Save" Click="OnSave" Background="#337F44"/>
                <Button Content="Load" Click="OnLoad" Background="#33447F"/>
                <Button Content="Clear" Click="OnClear" Background="#666"/>
                <Button Content="🔄 Sync to Tablet" Click="OnSyncToTablet" Margin="12,0,0,0" Background="#996611"/>
            </StackPanel>
        </Border>

        <!-- Canvas with scroll/zoom -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto" Background="#0A0A0A"
                      x:Name="ScrollHost"
                      PreviewMouseDown="OnScrollHostMouseDown"
                      PreviewMouseMove="OnScrollHostMouseMove"
                      PreviewMouseUp="OnScrollHostMouseUp">
            <Canvas x:Name="WhiteboardCanvas" Width="4000" Height="4000"
                                        Background="#0A0A0A"
                                        MouseWheel="OnCanvasMouseWheel">
                                <Canvas.RenderTransform>
                                        <TransformGroup>
                                                <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                                                <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0"/>
                                        </TransformGroup>
                                </Canvas.RenderTransform>
                        </Canvas>
        </ScrollViewer>

        <!-- Sending overlay -->
        <Border x:Name="SendingOverlay" Grid.Row="0" Grid.RowSpan="2"
                Background="#CC000000" Visibility="Collapsed"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="SendingLabel" Text="Sending image..."
                           Foreground="White" FontSize="20"
                           HorizontalAlignment="Center"/>
                <ProgressBar x:Name="SendingProgress" Width="300" Height="20"
                             Margin="0,12,0,0" Minimum="0" Maximum="100"
                             Foreground="#4488FF"/>
            </StackPanel>
        </Border>

        <!-- Document Mode Directory Path -->
        <Border Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="16" IsHitTestVisible="False" Background="#99000000" CornerRadius="8" Padding="12,6">
            <TextBlock x:Name="DocModePathText" Foreground="#AACCFF" FontSize="14" Visibility="Collapsed"/>
        </Border>
    </Grid>
</Window>
